{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-basic-crud-products",
    "name": "Basic CRUD — Products",
    "description": "REST CRUD for /api/products (Spring Boot sample app).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "productId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "List all products",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/products"
      }
    },
    {
      "name": "Get product by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/products/{{productId}}"
      }
    },
    {
      "name": "Create product",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Desk Lamp\",\n  \"description\": \"LED dimmable\",\n  \"price\": 45.00\n}"
        },
        "url": "{{baseUrl}}/api/products"
      }
    },
    {
      "name": "Update product",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Desk Lamp Pro\",\n  \"description\": \"LED dimmable, warm white\",\n  \"price\": 49.99\n}"
        },
        "url": "{{baseUrl}}/api/products/{{productId}}"
      }
    },
    {
      "name": "Delete product",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/api/products/{{productId}}"
      }
    }
  ]
}
